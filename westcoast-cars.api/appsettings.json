{
  "JwtSettings": {
    "Issuer": "WestcoastCars.Api",
    "Audience": "WestcoastCars.Api",
    "ExpiryMinutes": 60
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=db;Port=3306;Database=westcoast_cars_db;Uid=root;Pwd=${MYSQL_PASSWORD};"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "DataProtectionPath": "/app/keys"
}