## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
##
## Get latest from https://github.com/github/gitignore/blob/main/VisualStudio.gitignore

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates
*.env

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Mono auto generated files
mono_crash.*

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio 2015 cache/options directory
.vs/

# Visual Studio 2017 cache/options directory
.vs/

# Visual Studio 2019 cache/options directory
.vs/

# Visual Studio 2022 cache/options directory
.vs/

# Rider cache/options directory
.idea/

# Mac meta files
._*

# Windows thumbnail cache files
Thumbs.db

# Umbraco files
/App_Data/TEMP/
/App_Data/Models/
/App_Data/Logs/

# NuGet Packages
*.nupkg
# The packages folder can be ignored because of Package Restore
**/[Pp]ackages/*
# except build/, which is used as an MSBuild target.
!**/[Pp]ackages/build/
# Uncomment if you don't want to check in your restored packages
#packages/
# NuGet v3's project.json lock file
project.lock.json
# NuGet v3's project.assets.json file
project.assets.json

# Visual Studio cache files
# files ending in .cache can be ignored
*.[Cc]ache
# but keep track of directories named .cache
!*.[Cc]ache/

# C++ Build files
ipch/
*.aps
*.ncb
*.opendb
*.sdf
*.tlog
*.log
*.ilk
*.psess
*.gpess
*.vspx
*.vsp
*.map
*.pdb
*.obj
*.iobj
*.pch
*.ipch
*.pgc
*.pgd
*.rsp
*.sbr
*.tmp
*.tmp_proj
*.db

# Visual C++ cache files
[Vv][Cc][Xx]srv/

# Visual Studio profiler
*.psess
*.vsp
*.vspx
*.sap

# Visual Studio Trace Files
*.etl

# Roslyn files
*.ruleset

# StyleCop
StyleCop.Cache
stylecop.json

# Fakes
Generated\/

# FxCop
*.Fakes.xml

# CodeMaid
*.orig

# NCrunch
_NCrunch_*.csproj
*.ncrunchproject
*.vb.ncrunchproject
*.csproj.ncrunchproject

# R#
_ReSharper*
*.[Rr]e[Ss]harper
*.DotSettings.user

# JustDecompile
*.jdsettings

# DotCover
*.dotcover

# Test-results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*
*.[Pp]ublish.xml
*.[Dd]eploy.xml

# Telerik's JustMock configuration file
*.jmconfig

# BizTalk
*.btp.cs
*.btm.cs
*.odx.cs
*.xsd.cs

# TeamCity
TeamCity.xml

# Dotfuscator
*.dotfuscator
*.map.xml

# SonarQube
.sonarlint/
.sonarqube/

# GhostDoc
*.ghostdoc

# AppVeyor
.appveyor.yml

# NUnit
nunit-*.xml
NUnit-*.xml

# MSTest
*.trx
*.coverage
*.coveragexml

# xUnit
xunit-*.xml
xunit-*.html
xunit-*.json

# CodeRush
.cr/

# BenchmarkDotNet
BenchmarkDotNet.Artifacts/

# Paket
.paket/paket.exe
paket-files/

# Cake
tools/

# Output from `dotnet watch`
hotreload.json

# Local database files
westcoastcars.db
