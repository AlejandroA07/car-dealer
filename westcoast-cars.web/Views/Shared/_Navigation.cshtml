<nav class="navbar">
    <h1 class="logo"><span class="text-primary"><i class="fa-solid fa-car"></i> Westcoast</span> Cars</h1>
    <ul>
        <li><a asp-action="Index" asp-controller="Home">Hem</a></li>
        <li><a asp-action="Index" asp-controller="Vehicles">Våra bilar</a></li>
        <li><a href="#">Boka Service</a></li>
        @if (User.IsInRole("Admin") || User.IsInRole("Salesperson"))
        {
            <li><a asp-action="Index" asp-controller="Admin"><i class="fa-solid fa-plus"></i></a></li>
        }
        @if (User.Identity.IsAuthenticated)
        {
            <li><span class="text-white" style="padding: 0.8rem 0.5rem; margin: 0 0.4rem;">Welcome, @(User.Identity.Name?.Split('@')[0])!</span></li>
            <li>
                <form asp-controller="Auth" asp-action="Logout" method="post" id="logoutForm" style="display:inline; width:auto; padding:0; background:none; box-shadow:none; margin:0;">
                    <a href="javascript:document.getElementById('logoutForm').submit()" style="color: var(--light-color); padding: 0.8rem 0.5rem; margin: 0 0.4rem;">Logout</a>
                </form>
            </li>
        }
        else
        {
            <li><a asp-controller="Auth" asp-action="Login" class="nav-link text-white">Login</a></li>
        }
    </ul>
</nav>