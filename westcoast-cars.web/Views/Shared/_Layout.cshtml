<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="~/css/colors.css">
    <link rel="stylesheet" href="~/css/navigation.css">
    <link rel="stylesheet" href="~/css/utilities.css">
    <link rel="stylesheet" href="~/css/gallery-page.css">
    @RenderSection("styles", false)
    <link rel="stylesheet" href="~/css/site.css">
    <link rel="stylesheet" href="~/css/vehicle-detail-page.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/css/toastr.min.css" />
    <script src="https://kit.fontawesome.com/8dda4e2421.js" crossorigin="anonymous"></script>
    <title>@ViewData["Title"] Westcoast Cars</title>
</head>
<body>
    <header>
        @await Html.PartialAsync("_Navigation")
        @if (Model is westcoast_cars.web.ViewModels.Vehicles.VehicleListViewModel)
        {
            <div class="search-bar-container">
                @await Html.PartialAsync("_SearchForm", (westcoast_cars.web.ViewModels.Vehicles.VehicleListViewModel)Model)
            </div>
        }
    </header>
    <main class="@(Model is westcoast_cars.web.ViewModels.Vehicles.VehicleListViewModel ? "" : "no-search")">
        @RenderBody()
            @* <section>
                @await Html.PartialAsync("_WeeklyOffer")
            </section> *@
        </main>

    <div id="sidebarOverlay" class="sidebar-overlay"></div>
    <div id="sidebar" class="sidebar">
        <span id="closeBtn" class="close-btn">&times;</span>
        <h2>Meny</h2>
        <ul class="sidebar-links">
            <li><a asp-action="Index" asp-controller="Vehicles"><i class="fa-solid fa-car"></i> Våra bilar</a></li>
            <li><a asp-action="Index" asp-controller="Service"><i class="fa-solid fa-wrench"></i> Boka service</a></li>
            @if (!User.Identity.IsAuthenticated)
            {
                <li><a asp-action="Login" asp-controller="Auth"><i class="fa-solid fa-right-to-bracket"></i> Logga in</a></li>
                <li><a href="#"><i class="fa-solid fa-user-plus"></i> Skapa konto</a></li>
            }
            else
            {
                <li>
                    <form asp-controller="Auth" asp-action="Logout" method="post" id="sidebarLogoutForm" style="display:none;"></form>
                    <a href="javascript:document.getElementById('sidebarLogoutForm').submit()">
                        <i class="fa-solid fa-right-from-bracket"></i> Logga ut
                    </a>
                </li>
            }
        </ul>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/js/toastr.min.js"></script>
    <script>
        $(document).ready(function() {
            const sidebar = $('#sidebar');
            const overlay = $('#sidebarOverlay');

            $('#menuBtn').on('click', function() {
                sidebar.addClass('active');
                overlay.addClass('active');
                $('body').css('overflow', 'hidden'); // Prevent scrolling
            });

            $('#closeBtn, #sidebarOverlay').on('click', function() {
                sidebar.removeClass('active');
                overlay.removeClass('active');
                $('body').css('overflow', 'auto');
            });
        });
    </script>
    @await Html.PartialAsync("_Notification")
    @RenderSection("Scripts", required: false)
</body>
</html>
