@model westcoast_cars.web.ViewModels.Vehicles.VehiclePostViewModel

<section class="page">
    <h1 class="page-title">Lägg till bil</h1>
    <form asp-action="Create" method="post">
        <div asp-validation-summary="All" class="error"></div>
        <div class="form-control">
            <label asp-for="RegistrationNumber"></label>
            <input asp-for="RegistrationNumber" type="text">
            <span class="error" asp-validation-for="RegistrationNumber"></span>
        </div>

        <div class="form-control">
            <label asp-for="ManufacturerId"></label>
            <select asp-for="ManufacturerId" asp-items="Model.Manufacturers"></select>
            <span class="error" asp-validation-for="ManufacturerId"></span>
        </div>
        <div class="form-control">
            <label asp-for="Model"></label>
            <input asp-for="Model" type="text">
            <span class="error" asp-validation-for="Model"></span>
        </div>
        <div class="form-control">
            <label asp-for="ModelYear"></label>
            <input asp-for="ModelYear" type="text">
            <span class="error" asp-validation-for="ModelYear"></span>
        </div>
        <div class="form-control">
            <label asp-for="FuelTypeId"></label>
            <select asp-for="FuelTypeId" asp-items="Model.FuelTypes"></select>
            <span class="error" asp-validation-for="FuelTypeId"></span>
        </div>
        <div class="form-control">
            <label asp-for="TransmissionTypeId"></label>
            <select asp-for="TransmissionTypeId" asp-items="Model.TransmissionsTypes"></select>
            <span class="error" asp-validation-for="TransmissionTypeId"></span>
        </div>
        <div class="form-control">
            <label asp-for="Mileage"></label>
            <input asp-for="Mileage" type="text">
            <span class="error" asp-validation-for="Mileage"></span>
        </div>
        <div class="form-control">
            <label asp-for="Description"></label>
            <textarea asp-for="Description"></textarea>
            <span class="error" asp-validation-for="Description"></span>
        </div>
        <div class="form-control">
            <div class="buttons-container">
                <button type="submit" class="btn btn-primary">Spara</button>
                <a asp-action="Index" class="btn btn-warning">Avbryt</a>
            </div>
        </div>
    </form>
</section>