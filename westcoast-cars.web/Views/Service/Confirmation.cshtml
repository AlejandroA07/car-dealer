@{
    ViewData["Title"] = "Bokningsbekräftelse";
}

<section class="page">
    <div class="confirmation-container" style="max-width: 600px; margin: 4rem auto; text-align: center; background: white; padding: 4rem 2rem; border-radius: 8px; box-shadow: 0 4px 10px rgba(0,0,0,0.1);">
        <i class="fa-solid fa-circle-check" style="font-size: 5rem; color: #28a745; margin-bottom: 2rem;"></i>
        <h1 style="margin-bottom: 1.5rem; color: var(--dark-color);">Bokningsförfrågan skickad!</h1>
        <p style="font-size: 1.2rem; line-height: 1.6; color: #555; margin-bottom: 2.5rem;">
            Tack för din bokning. Vi har tagit emot din förfrågan och kommer att kontakta dig via e-post eller telefon så snart som möjligt för att bekräfta din tid.
        </p>
        <div style="display: flex; gap: 1rem; justify-content: center;">
            <a asp-action="Index" asp-controller="Home" class="btn btn-primary" style="padding: 0.8rem 2rem;">Tillbaka till Hem</a>
            <a asp-action="Index" asp-controller="Vehicles" class="btn btn-dark" style="padding: 0.8rem 2rem;">Se våra bilar</a>
        </div>
    </div>
</section>
