@model westcoast_cars.web.ViewModels.Auth.LoginViewModel

@{
    ViewData["Title"] = "Login";
    Layout = "_Layout";
}

<section class="page">
    <h1 class="page-title">Login</h1>
    <form asp-controller="Auth" asp-action="Login" asp-route-returnurl="@Model.ReturnUrl" method="post">
        <div asp-validation-summary="All" class="error"></div>
        <div class="form-control">
            <label asp-for="Email"></label>
            <input asp-for="Email" type="text" />
            <span class="error" asp-validation-for="Email"></span>
        </div>
        <div class="form-control">
            <label asp-for="Password"></label>
            <input asp-for="Password" type="password" />
            <span class="error" asp-validation-for="Password"></span>
        </div>
        <div class="form-control">
            <input asp-for="RememberMe" type="checkbox" />
            <label asp-for="RememberMe"></label>
        </div>
        <div class="form-control">
            <div class="buttons-container">
                <button type="submit" class="btn btn-primary">Login</button>
                <a asp-action="Index" asp-controller="Home" class="btn btn-warning">Cancel</a>
            </div>
        </div>
    </form>
</section>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
